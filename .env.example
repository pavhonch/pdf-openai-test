DATABASE_URL=sqlite:///./data/app.db
UPLOAD_DIR=uploads
MAX_UPLOAD_MB=50
# Cap on extracted text length before chunking/LLM (cost/latency guard for demos).
# Invalid or non-positive values fall back to 350000.
MAX_TOTAL_CHARS=350000
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# OpenRouter: use your real key only in a local .env file.
OPENROUTER_API_KEY=replace-with-your-openrouter-key
OPENROUTER_MODEL=openai/gpt-4o-mini
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=
OPENROUTER_SITE_URL=

# Frontend (Vite): set when not using defaults. Never put API keys here.
VITE_API_URL=http://localhost:8000
